{
  "enabled": true,
  "allowBrowserProcess": true,
  "network": {
    "allowLocalBinding": true,
    "allowAllUnixSockets": true,
    "allowedDomains": [
      "localhost",
      "127.0.0.1",
      "html.duckduckgo.com",
      "*.npmjs.org",
      "*.pypi.org",
      "*.github.com",
      "raw.githubusercontent.com",
      "mcp.context7.com"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "allowRead": [
      ".",
      "~/.config",
      "~/.cargo",
      "~/.local",
      "~/.cache"
    ],
    "denyRead": [
      "/home"
    ],
    "allowWrite": [
      ".",
      "/tmp",
      "~/.cache",
      "~/.rustup",
      "~/.agent-browser"
    ],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key"
    ]
  }
}